{
  "manifest_version": 3,
  "name": "AI Refund Copilot",
  "version": "1.0.0",
  "description": "基于 AI 自动生成退款邮件的浏览器助手",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Refund Copilot"
  },
  "content_scripts": [
    {
      "matches": ["*://*.amazon.com/*", "*://*.amazon.co.uk/*", "*://*.amazon.de/*", "*://*.amazon.co.jp/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
